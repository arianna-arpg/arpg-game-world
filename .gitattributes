# Normalize all text files to LF inside the repo, so line endings
# stay consistent no matter who checks out on Windows/Mac/Linux.
* text=auto eol=lf

# Windows launcher scripts must keep CRLF or they can misbehave.
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Treat these as binary (never diffed or line-ending-converted).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.mp3  binary
*.wav  binary
*.ogg  binary
*.ttf  binary
*.woff binary
*.woff2 binary
*.exe  binary
*.node binary
*.bin  binary
