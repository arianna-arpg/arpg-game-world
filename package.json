{
  "name": "arpg-test-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "launcher/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit && tsc -p tsconfig.launcher.json",
    "game": "electron .",
    "game:play": "electron . --play",
    "smoke": "electron . --smoke-test=game",
    "smoke:launcher": "electron . --smoke-test=launcher"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
