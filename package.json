{
  "name": "arpg-test-game",
  "private": true,
  "version": "0.3.0",
  "description": "Hollow Wake — a data-driven top-down action RPG (TypeScript + Canvas 2D + Electron).",
  "author": "Arianna",
  "repository": "github:arianna-arpg/arpg-game-world",
  "type": "module",
  "main": "launcher/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:web": "vite build --base=./ --outDir site/play --emptyOutDir",
    "build:portraits": "vite build --config vite.portraits.config.ts",
    "preview": "vite preview",
    "check": "tsc --noEmit && tsc -p tsconfig.launcher.json && tsc -p tsconfig.sim.json",
    "sim": "tsx balance/cli.ts",
    "genqa": "tsx balance/genqa.ts",
    "eventqa": "tsx balance/eventqa.ts",
    "review:context": "node scripts/ai-review-context.mjs",
    "export-web-data": "tsx scripts/export-web-data.ts",
    "game": "electron .",
    "game:play": "electron . --play",
    "smoke": "electron . --smoke-test=game",
    "smoke:launcher": "electron . --smoke-test=launcher",
    "perf": "electron . --perf-test",
    "icon": "node scripts/make-icon.mjs",
    "dist": "npm run build && node scripts/make-build-info.mjs && electron-builder --win --publish never",
    "dist:linux": "npm run build && node scripts/make-build-info.mjs && electron-builder --linux --publish never",
    "dist:all": "npm run build && node scripts/make-build-info.mjs && electron-builder --win --linux --publish never"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
