# ── Dependencies ─────────────────────────────────────────────
# Restored with `npm install`; never committed.
node_modules/

# ── Build output ─────────────────────────────────────────────
# Vite build; regenerate with `npm run build`.
# NOTE: if you ever want to version a shippable build, remove this line.
dist/
dist-ssr/
*.tsbuildinfo

# ── Packaged executables ─────────────────────────────────────
# electron-builder output (`npm run dist`): installers, AppImages,
# win-unpacked/. Rebuild at will; releases live on GitHub.
release/
# Stamped by scripts/make-build-info.mjs on every dist run (ships
# inside the package as an extraResource). build/icon.png IS
# committed — it's an asset, not output.
build/build-info.json

# ── In-browser demo build ────────────────────────────────────
# The playable web demo is built into site/play by CI (and locally
# with `npm run build:web`) via `vite build --outDir site/play`.
# Like dist/, it's generated output — never committed. CI rebuilds
# it on every deploy, so the live /play/ always matches the source.
/site/play/

# ── Game saves ───────────────────────────────────────────────
# Personal runtime state that changes every session. Ignored so
# your play history doesn't bloat the repo. To keep ONE sample
# save on purpose:  git add -f saves/save_0.json
saves/

# ── Claude Code local settings ───────────────────────────────
# Machine-specific paths/permissions — do not share.
.claude/settings.local.json
.claude/worktrees/

# ── Generated editor backups ─────────────────────────────────
# The dev passive-tree editor writes passives.ts.bak before each
# save; git history is the real backup, so these never ship.
*.bak

# ── Balance harness run artifacts ────────────────────────────
# Per-run simulation reports (JSON/MD/CSV) — regenerate with
# `npm run sim -- run …`. BASELINES (balance/baselines/) are
# committed on purpose; only the per-run output is transient.
balance/reports/

# ── Desktop launcher local overrides ─────────────────────────
# Machine-specific window/port/update preferences; deep-merged
# over the committed launcher.config.json defaults.
launcher.config.local.json

# ── Claude Code scratch / one-off verification scripts ───────
# Created at the project root during debugging. Anchored to root
# with a leading slash so nothing inside src/ is affected.
/*_verify.*
/*_probe.*
/*_repro.*
/colossus_*

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Editor / OS junk ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.sw?
